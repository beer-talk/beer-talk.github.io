---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SessionCard from '../../components/SessionCard.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const speakers = await getCollection('speakers');
  const publishedSpeakers = speakers.filter(s => s.data.status === 'published');
  return publishedSpeakers.map(speaker => ({
    params: { slug: speaker.id },
    props: { speaker },
  }));
}

const { speaker } = Astro.props;
const { Content } = await render(speaker);
const { name, title, company, github, twitter, linkedin, website, avatarUrl } = speaker.data;

// Find sessions presented by this speaker
const allSessions = await getCollection('sessions');
const speakerSessions = allSessions.filter(s => 
  s.data.speakers && s.data.speakers.includes(speaker.id)
);
---

<BaseLayout title={`${name} - {{SITE_NAME}}`} description={`Speaker profile for ${name}`}>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
    <div class="mb-10 text-center">
      <div class="inline-block relative">
        <div class="w-32 h-32 rounded-full overflow-hidden bg-slate-200 dark:bg-slate-800 border-4 border-white dark:border-slate-950 shadow-xl mx-auto mb-6 transition-colors duration-300">
          {avatarUrl ? (
            <img src={avatarUrl} alt={name} class="w-full h-full object-cover" />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-4xl text-slate-400 dark:text-slate-500 font-bold bg-indigo-50 dark:bg-indigo-900/40">
              {name.charAt(0)}
            </div>
          )}
        </div>
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 dark:text-white tracking-tight leading-tight">{name}</h1>
      <p class="text-xl text-primary dark:text-indigo-400 font-medium mt-2">
        {title} {company && <span class="text-slate-500 dark:text-slate-400 font-light">at {company}</span>}
      </p>
      
      <div class="flex items-center justify-center gap-4 mt-6">
        {twitter && <a href={twitter} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-blue-400 dark:text-slate-500 transition-colors">Twitter</a>}
        {github && <a href={github} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-slate-900 dark:text-slate-500 dark:hover:text-white transition-colors">GitHub</a>}
        {linkedin && <a href={linkedin} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-blue-700 dark:text-slate-500 transition-colors">LinkedIn</a>}
        {website && <a href={website} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-primary dark:text-slate-500 transition-colors">Website</a>}
      </div>
    </div>
    
    <div class="prose prose-lg prose-slate dark:prose-invert text-slate-700 dark:text-slate-300 max-w-none mb-16">
      <Content />
    </div>

    {speakerSessions.length > 0 && (
      <div class="pt-12 border-t border-slate-100 dark:border-slate-800 transition-colors duration-300">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-8">Sessions by {name}</h2>
        <div class="space-y-4">
          {speakerSessions.map(session => (
            <SessionCard session={session} />
          ))}
        </div>
      </div>
    )}
  </article>
</BaseLayout>
