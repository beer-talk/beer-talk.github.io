---
import BaseLayout from '../layouts/BaseLayout.astro';
import SessionCard from '../components/SessionCard.astro';
import { getEntry, getCollection } from 'astro:content';
import { SITE_CONFIG } from '../content/site-config';

const currentEdition = await getEntry('editions', SITE_CONFIG.currentEditionSlug);

const allSessions = await getCollection('sessions');
const currentSessions = allSessions.filter(s => s.data.edition === SITE_CONFIG.currentEditionSlug && s.data.status === 'published');

// Sort sessions by time, fallback to sortOrder
currentSessions.sort((a, b) => {
  if (a.data.startTime && b.data.startTime) {
    const timeCompare = a.data.startTime.localeCompare(b.data.startTime);
    if (timeCompare !== 0) return timeCompare;
  }
  return (a.data.sortOrder || 0) - (b.data.sortOrder || 0);
});

const { name, theme, speakerProposalUrl } = currentEdition?.data || {};
---

<BaseLayout title={`Lịch trình - ${name || '{{SITE_NAME}}'}`} description={`Lịch trình sự kiện ${name}`}>
  <div class="bg-slate-50 dark:bg-[#0b0f19] py-24 sm:py-32 transition-colors duration-300 min-h-screen relative overflow-hidden">
    <!-- Background element -->
    <div class="absolute top-0 left-0 w-1/2 h-1/2 bg-primary/5 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-24">
        <h1 class="text-5xl sm:text-7xl font-black text-slate-900 dark:text-white tracking-tighter mb-6 uppercase">Lịch trình <span class="text-primary dark:text-accent font-light italic">Sự kiện</span></h1>
        <div class="w-16 h-1 bg-gradient-to-r from-primary to-accent mx-auto mb-6"></div>
        <p class="text-xl text-slate-500 dark:text-slate-400 font-light max-w-2xl mx-auto">{name ? `Lịch trình sự kiện ${name}` : 'Tham gia cùng chúng tôi để có một buổi tối chia sẻ kỹ thuật chuyên sâu.'}</p>
      </div>
      
      {currentSessions.length > 0 ? (
        <div class="space-y-4 relative before:absolute before:inset-0 before:ml-5 sm:before:ml-8 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-[2px] before:bg-gradient-to-b before:from-transparent before:via-white/10 before:to-transparent">
          {currentSessions.map(session => (
            <SessionCard session={session} />
          ))}
        </div>
      ) : (
        <div class="bg-white/50 dark:bg-[#050812] border border-slate-200 dark:border-white/10 rounded-none p-16 text-center max-w-3xl mx-auto relative overflow-hidden">
          <div class="absolute inset-0 bg-center [mask-image:linear-gradient(180deg,white,rgba(255,255,255,0))] opacity-30" style={`background-image: url('${getPath('/grid.svg')}');`}></div>
          <div class="relative z-10">
            <h2 class="text-2xl font-black text-slate-900 dark:text-white items-center gap-2 mb-4 tracking-tight"><svg class="inline-block w-6 h-6 text-accent mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>Đang tải Dữ liệu</h2>
            <p class="text-lg text-slate-500 dark:text-slate-400 mb-8 font-light max-w-lg mx-auto">Chúng tôi đang biên dịch lịch trình cho sự kiện. Vui lòng quay lại sau!</p>
            {speakerProposalUrl && (
              <a href={speakerProposalUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-8 py-4 border border-white/20 text-sm tracking-widest uppercase font-bold text-white bg-transparent hover:border-accent hover:bg-white/5 transition-all focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 dark:focus:ring-offset-[#050812]">
                Bạn muốn làm diễn giả?
              </a>
            )}
          </div>
        </div>
      )}
    </div>
  </div>
</BaseLayout>
