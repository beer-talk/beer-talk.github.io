---
import BaseLayout from '../layouts/BaseLayout.astro';
import SpeakerCard from '../components/SpeakerCard.astro';
import SessionCard from '../components/SessionCard.astro';
import { getEntry, getCollection, render } from 'astro:content';
import { SITE_CONFIG } from '../content/site-config';
import { getPath } from '../utils/paths';

// Fetch the current edition
const currentEdition = await getEntry('editions', SITE_CONFIG.currentEditionSlug);
let Content = null;
if (currentEdition) {
  const rendered = await render(currentEdition);
  Content = rendered.Content;
}

// Index no longer needs to fetch all sessions or speakers, as they have their own pages.

const { 
  name, 
  date, 
  time, 
  venueName, 
  venueAddress, 
  theme, 
  registrationUrl, 
  speakerProposalUrl,
  highlights,
  faq 
} = currentEdition?.data || {};

---

<BaseLayout title={name || '{{SITE_NAME}}'} description={theme || '{{SITE_DESCRIPTION}}'}>
  {!currentEdition ? (
    <div class="max-w-7xl mx-auto py-32 px-4 text-center">
      <h1 class="text-4xl font-bold text-gray-900">Please create <code>src/content/editions/{SITE_CONFIG.currentEditionSlug}.md</code></h1>
    </div>
  ) : (
    <>
      {/* 1. Hero Section */}
      <section class="relative bg-[#050812] text-white overflow-hidden py-32 sm:py-48 border-b border-white/10">
        <!-- Abstract glowing orbs in background -->
        <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary/20 rounded-full blur-[100px] pointer-events-none z-0"></div>
        <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-accent/10 rounded-full blur-[100px] pointer-events-none z-0"></div>
        
        <div class="absolute inset-0 bg-cover bg-center" style={`background-image: url('${getPath('/hero-bg.jpg')}');`}></div>
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#050812]/50 to-[#050812]"></div>
        <div class="absolute inset-0 bg-center [mask-image:linear-gradient(180deg,white,rgba(255,255,255,0))] opacity-30" style={`background-image: url('${getPath('/grid.svg')}');`}></div>
        
        <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
          <div class="flex flex-col items-center sm:items-start text-center sm:text-left">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-accent font-mono text-sm tracking-wide uppercase mb-8 shadow-neon">
              <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
              {date} {time && `• ${time}`}
            </div>
            
            <h1 class="text-6xl sm:text-8xl md:text-9xl font-black tracking-tighter mb-6 leading-[0.9] text-transparent bg-clip-text bg-gradient-to-r from-white via-white to-slate-400 drop-shadow-sm">
              {name}
            </h1>
            
            {theme && 
              <p class="text-2xl sm:text-4xl text-slate-300 mb-12 max-w-3xl font-light tracking-tight border-l-4 border-primary pl-6 py-2">
                {theme}
              </p>
            }
            
            <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4 sm:gap-6 mt-4 w-full sm:w-auto">
              {registrationUrl ? (
                <a href={registrationUrl} target="_blank" rel="noopener noreferrer" class="group relative px-10 py-5 bg-primary text-white font-bold uppercase tracking-widest text-sm sm:text-base rounded-full hover:bg-orange-500 hover:shadow-neon-primary transition-all duration-300 flex-1 sm:flex-none text-center border border-transparent overflow-hidden">
                  <span class="relative z-10">Đăng ký tham gia</span>
                  <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out z-0"></div>
                </a>
              ) : (
                <span class="px-10 py-5 bg-white/5 text-slate-400 font-bold uppercase tracking-widest text-sm sm:text-base cursor-not-allowed border border-white/10 text-center rounded-full backdrop-blur-sm">
                  Sắp mở đăng ký
                </span>
              )}
              
              {speakerProposalUrl && (
                <a href={speakerProposalUrl} target="_blank" rel="noopener noreferrer" class="px-10 py-5 bg-transparent text-white font-bold uppercase tracking-widest text-sm sm:text-base rounded-full border border-white/20 hover:border-primary hover:bg-primary/10 hover:text-primary hover:shadow-neon-primary transition-all duration-300 text-center backdrop-blur-sm">
                  Trở thành diễn giả
                </a>
              )}
            </div>
          </div>
        </div>
      </section>

      {/* 2. About the Event */}
      {Content && (
        <section class="bg-slate-50 dark:bg-[#0b0f19] py-32 border-b border-slate-200 dark:border-white/5 relative">
          <div class="absolute inset-0 block dark:hidden bg-white/50"></div>
          <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="text-center mb-16">
              <h2 class="text-sm font-black tracking-widest uppercase text-accent mb-4">Về Sự Kiện</h2>
              <div class="w-16 h-1 bg-gradient-to-r from-accent to-primary mx-auto"></div>
            </div>
            <div class="prose prose-lg prose-slate dark:prose-invert md:prose-xl mx-auto text-slate-700 dark:text-slate-300 leading-relaxed font-sans font-light">
              <Content /> 
            </div>
          </div>
        </section>
      )}

      {/* 3. Highlights Section */}
      {highlights && highlights.length > 0 && (
        <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {highlights.map(h => (
              <div class="bg-white/50 dark:bg-[#0b0f19] backdrop-blur-sm p-10 rounded-[2rem] border border-slate-200 dark:border-white/5 hover:border-primary/50 dark:hover:border-primary/50 transition-all duration-500 group relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-primary/0 to-primary/0 group-hover:from-primary/5 group-hover:to-accent/5 transition-colors duration-500 z-0"></div>
                <div class="relative z-10">
                  <div class="w-16 h-16 bg-slate-100 dark:bg-[#050812] rounded-2xl border border-slate-200 dark:border-white/10 text-primary dark:text-primary flex items-center justify-center mb-8 group-hover:scale-110 transition-transform duration-500 shadow-sm dark:shadow-neon-primary">
                    {h.icon ? (
                      <span class="text-3xl">{h.icon}</span>
                    ) : (
                      <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                    )}
                  </div>
                  <h3 class="text-2xl font-display font-bold text-slate-900 dark:text-white mb-4 tracking-tight">{h.title}</h3>
                  <p class="text-slate-600 dark:text-slate-400 font-light leading-relaxed">{h.description}</p>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {/* Call to Talk Section */}
      <section class="bg-slate-50 dark:bg-[#0b0f19] py-32 border-y border-slate-200 dark:border-white/5 relative overflow-hidden">
        <div class="absolute right-0 top-1/2 -translate-y-1/2 w-96 h-96 bg-primary/5 rounded-full blur-[100px] pointer-events-none z-0"></div>
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
          <h2 class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white mb-6 tracking-tighter uppercase">Call to <span class="text-primary dark:text-accent font-light italic">Talk</span></h2>
          <div class="w-16 h-1 bg-gradient-to-r from-primary to-accent mx-auto mb-8"></div>
          <p class="text-xl text-slate-600 dark:text-slate-400 font-light mb-12 max-w-3xl mx-auto leading-relaxed">
            Bạn có một câu chuyện công nghệ thú vị, một case study đáng để học hỏi hay một ý tưởng đột phá? Hãy chia sẻ kiến thức và đam mê của bạn bằng cách trở thành diễn giả tại sự kiện tiếp theo của chúng tôi.
          </p>
          <a href={getPath('/call-to-talk')} class="group relative px-10 py-5 bg-transparent border border-primary text-primary font-bold uppercase tracking-widest text-sm sm:text-base rounded-full hover:bg-primary/10 hover:shadow-neon-primary transition-all duration-300 inline-flex items-center gap-3">
            <span>Tìm hiểu thêm & Đăng ký</span>
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </a>
        </div>
      </section>

      {/* 4. Quick Links CTA */}
      <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-24 pb-32 text-center">
        <h2 class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white mb-16 tracking-tighter">Sẵn Sàng Tham Gia?</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <a href={getPath('/agenda')} class="group bg-white dark:bg-[#0b0f19] rounded-[2rem] p-10 border border-slate-200 dark:border-white/5 hover:border-primary/50 dark:hover:border-primary/50 transition-all duration-500 flex flex-col items-center hover:-translate-y-2 hover:shadow-xl dark:hover:shadow-neon-primary relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-b from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <svg class="w-12 h-12 text-primary dark:text-primary mb-6 group-hover:scale-110 transition-transform duration-500 relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <h3 class="text-2xl font-display font-bold text-slate-900 dark:text-white relative z-10 tracking-tight">Lịch trình</h3>
            <p class="text-slate-600 dark:text-slate-400 mt-3 font-light relative z-10 text-sm">Xem toàn bộ lịch trình</p>
          </a>
          <a href={getPath('/speakers')} class="group bg-white dark:bg-[#0b0f19] rounded-[2rem] p-10 border border-slate-200 dark:border-white/5 hover:border-primary/50 dark:hover:border-primary/50 transition-all duration-500 flex flex-col items-center hover:-translate-y-2 hover:shadow-xl dark:hover:shadow-neon-primary relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-b from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <svg class="w-12 h-12 text-primary dark:text-primary mb-6 group-hover:scale-110 transition-transform duration-500 relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
            <h3 class="text-2xl font-display font-bold text-slate-900 dark:text-white relative z-10 tracking-tight">Diễn giả</h3>
            <p class="text-slate-600 dark:text-slate-400 mt-3 font-light relative z-10 text-sm">Gặp gỡ các chuyên gia</p>
          </a>
          <a href={getPath('/location')} class="group bg-white dark:bg-[#0b0f19] rounded-[2rem] p-10 border border-slate-200 dark:border-white/5 hover:border-primary/50 dark:hover:border-primary/50 transition-all duration-500 flex flex-col items-center hover:-translate-y-2 hover:shadow-xl dark:hover:shadow-neon-primary relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-b from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <svg class="w-12 h-12 text-primary dark:text-primary mb-6 group-hover:scale-110 transition-transform duration-500 relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <h3 class="text-2xl font-display font-bold text-slate-900 dark:text-white relative z-10 tracking-tight">Địa điểm</h3>
            <p class="text-slate-600 dark:text-slate-400 mt-3 font-light relative z-10 text-sm">Bản đồ & FAQ</p>
          </a>
        </div>
      </section>
    
      <div class="py-24 bg-slate-100/50 dark:bg-[#050812] border-t border-slate-200 dark:border-white/5 text-center transition-colors duration-300 relative overflow-hidden">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-lg h-px bg-gradient-to-r from-transparent via-primary/50 dark:via-accent/50 to-transparent"></div>
        <a href={getPath("/editions")} class="group inline-flex items-center justify-center px-10 py-5 text-sm uppercase tracking-widest font-bold text-slate-900 dark:text-white border border-slate-300 dark:border-white/20 hover:border-primary dark:hover:border-accent hover:bg-white dark:hover:bg-white/5 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 dark:focus:ring-offset-slate-950">
           Các Sự Kiện Trước Đây
          <svg xmlns="http://www.w3.org/2000/svg" class="ml-3 w-5 h-5 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </>
  )}
</BaseLayout>
