---
import type { CollectionEntry } from 'astro:content';
import { getPath } from '../utils/paths';

interface Props {
  edition: CollectionEntry<'editions'>;
}

const { edition } = Astro.props;
const { name, date, theme } = edition.data;
---
<a href={getPath(`/editions/${edition.id}`)} class="block group h-full focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded-2xl">
  <div class="border border-slate-200 dark:border-slate-800 rounded-2xl p-8 bg-white dark:bg-slate-900 hover:border-primary/30 dark:hover:border-primary/50 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 ease-out h-full flex flex-col">
    <p class="text-sm font-semibold tracking-wide uppercase text-primary dark:text-indigo-400 mb-3">{date}</p>
    <h3 class="text-2xl font-bold text-slate-900 dark:text-white group-hover:text-primary transition-colors">{name}</h3>
    {theme && <p class="text-slate-600 dark:text-slate-400 mt-4 flex-grow font-light leading-relaxed">{theme}</p>}
    <div class="mt-8 text-primary dark:text-indigo-400 font-medium flex items-center gap-2 group-hover:gap-3 transition-all">
      Xem lưu trữ
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </div>
  </div>
</a>
