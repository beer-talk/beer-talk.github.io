---
import type { CollectionEntry } from 'astro:content';

interface Props {
  speaker: CollectionEntry<'speakers'>;
}

const { speaker } = Astro.props;
const { name, title, company, avatarUrl, github, twitter, linkedin, website, talkTitle } = speaker.data;
---
<div class="group relative flex flex-col items-center bg-white/50 dark:bg-[#0b0f19] border border-slate-200 dark:border-white/10 rounded-[2rem] p-8 hover:border-primary/50 dark:hover:border-primary/50 hover:shadow-xl dark:hover:shadow-neon-primary transition-all duration-500 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-0"></div>
  <a href={`/speakers/${speaker.id}`} class="absolute inset-0 z-10 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary"><span class="sr-only">Xem {name}</span></a>
  
  <div class="relative z-20 w-32 h-32 rounded-full overflow-hidden mb-6 bg-slate-100 dark:bg-[#0b0f19] border-2 border-white/20 dark:border-white/10 group-hover:border-primary dark:group-hover:border-accent transition-colors duration-500 mt-2">
    {avatarUrl ? (
      <img src={avatarUrl} alt={name} class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500" />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-slate-300 dark:text-slate-600 bg-slate-100 dark:bg-[#0b0f19]">
        <svg fill="currentColor" viewBox="0 0 24 24" class="w-16 h-16"><path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
      </div>
    )}
  </div>
  <h3 class="relative z-20 text-xl font-bold text-slate-900 dark:text-white text-center group-hover:text-primary dark:group-hover:text-accent transition-colors tracking-tight">{name}</h3>
  {title && <p class="relative z-20 text-sm text-slate-600 dark:text-slate-400 text-center mt-2 font-light">{title}{company && <span class="text-primary dark:text-accent font-medium"><br/>@ {company}</span>}</p>}
  
  {talkTitle && (
    <div class="relative z-20 mt-6 pt-6 border-t border-slate-200 dark:border-white/10 w-full text-center pointer-events-none">
      <p class="text-[10px] font-bold text-primary dark:text-accent uppercase tracking-widest mb-2">Trình bày</p>
      <p class="text-sm font-medium text-slate-800 dark:text-slate-200 line-clamp-2">{talkTitle}</p>
    </div>
  )}
  
  <div class="relative z-30 flex justify-center flex-wrap gap-x-4 gap-y-2 mt-auto pt-6">
    {github && <a href={github} target="_blank" rel="noopener noreferrer" class="text-[10px] font-bold uppercase tracking-widest text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors focus:outline-none focus:ring-1 focus:ring-primary">GitHub</a>}
    {twitter && <a href={twitter} target="_blank" rel="noopener noreferrer" class="text-[10px] font-bold uppercase tracking-widest text-slate-400 hover:text-blue-500 dark:hover:text-blue-400 transition-colors focus:outline-none focus:ring-1 focus:ring-primary">X</a>}
    {linkedin && <a href={linkedin} target="_blank" rel="noopener noreferrer" class="text-[10px] font-bold uppercase tracking-widest text-slate-400 hover:text-blue-700 dark:hover:text-blue-500 transition-colors focus:outline-none focus:ring-1 focus:ring-primary">LinkedIn</a>}
    {website && <a href={website} target="_blank" rel="noopener noreferrer" class="text-[10px] font-bold uppercase tracking-widest text-slate-400 hover:text-primary dark:hover:text-accent transition-colors focus:outline-none focus:ring-1 focus:ring-primary">Web</a>}
  </div>
</div>
