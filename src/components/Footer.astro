---
import { SITE_CONFIG } from '../content/site-config';
const today = new Date();
---
<footer class="bg-slate-50 dark:bg-[#050812] border-t border-slate-200 dark:border-white/10 mt-32 transition-colors duration-500 relative overflow-hidden">
  <!-- Decorative glowing line -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/3 h-[1px] bg-gradient-to-r from-transparent via-primary to-transparent opacity-50"></div>

  <div class="max-w-7xl mx-auto py-16 px-4 sm:px-6 lg:px-8 flex flex-col items-center relative z-10">
    <div class="mb-8">
      <span class="text-2xl font-black tracking-tighter text-slate-900 dark:text-white uppercase">{SITE_CONFIG.name}</span>
    </div>
    
    <p class="text-center text-[10px] tracking-widest uppercase font-bold text-slate-500 dark:text-slate-400 mb-8 max-w-md mx-auto">
      {SITE_CONFIG.tagline}
    </p>
    
    <div class="w-12 h-[1px] bg-slate-200 dark:bg-white/10 mb-8"></div>
    
    <p class="text-center text-xs font-light text-slate-400 dark:text-slate-500 mb-2">
      &copy; {today.getFullYear()} {SITE_CONFIG.organizerName}. Mọi quyền được bảo lưu.
    </p>
    
    <p class="text-center text-xs font-light text-slate-400 dark:text-slate-500">
      Liên hệ: <a href={`mailto:${SITE_CONFIG.organizerEmail}`} class="text-slate-900 dark:text-white font-medium hover:text-primary dark:hover:text-accent transition-colors underline decoration-slate-200 dark:decoration-white/20 hover:decoration-primary dark:hover:decoration-accent underline-offset-4 tracking-wide">{SITE_CONFIG.organizerEmail}</a>
    </p>
  </div>
</footer>
