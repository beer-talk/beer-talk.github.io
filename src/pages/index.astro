---
import BaseLayout from '../layouts/BaseLayout.astro';
import SpeakerCard from '../components/SpeakerCard.astro';
import SessionCard from '../components/SessionCard.astro';
import { getEntry, getCollection, render } from 'astro:content';
import { SITE_CONFIG } from '../content/site-config';
import { getPath } from '../utils/paths';

// Fetch the current edition
const currentEdition = await getEntry('editions', SITE_CONFIG.currentEditionSlug);
let Content = null;
if (currentEdition) {
  const rendered = await render(currentEdition);
  Content = rendered.Content;
}

// Index no longer needs to fetch all sessions or speakers, as they have their own pages.

const { 
  name, 
  date, 
  time, 
  venueName, 
  venueAddress, 
  theme, 
  registrationUrl, 
  speakerProposalUrl,
  highlights,
  faq 
} = currentEdition?.data || {};

---

<BaseLayout title={name || '{{SITE_NAME}}'} description={theme || '{{SITE_DESCRIPTION}}'}>
  {!currentEdition ? (
    <div class="max-w-7xl mx-auto py-32 px-4 text-center">
      <h1 class="text-4xl font-bold text-gray-900">Please create <code>src/content/editions/{SITE_CONFIG.currentEditionSlug}.md</code></h1>
    </div>
  ) : (
    <>
      {/* 1. Hero Section */}
      <section class="relative bg-slate-900 text-white overflow-hidden py-24 sm:py-32 border-b-[6px] border-primary">
        <div class="absolute inset-0 bg-[url('/grid.svg')] bg-center [mask-image:linear-gradient(180deg,white,rgba(255,255,255,0))]"></div>
        <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
          <p class="text-blue-300 font-bold tracking-widest uppercase mb-6 text-sm sm:text-base">{date} {time && `• ${time}`}</p>
          <h1 class="text-5xl sm:text-7xl font-extrabold tracking-tight mb-8 leading-tight">{name}</h1>
          {theme && <p class="text-2xl sm:text-3xl text-gray-300 mb-12 max-w-3xl mx-auto font-light leading-relaxed">"{theme}"</p>}
          
          <div class="flex flex-col sm:flex-row items-center justify-center gap-6 mt-8">
            {registrationUrl ? (
              <a href={registrationUrl} target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto px-10 py-5 bg-primary text-white font-bold rounded-xl hover:bg-blue-600 transition-colors shadow-lg hover:shadow-xl text-lg hover:-translate-y-0.5 transform duration-200 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-slate-900">
                Đăng ký Tham gia
              </a>
            ) : (
              <span class="w-full sm:w-auto px-10 py-5 bg-slate-800 text-slate-400 font-bold rounded-xl cursor-not-allowed border border-slate-700 text-lg">
                Sắp dự Kiến Mở Đăng ký
              </span>
            )}
            
            {speakerProposalUrl && (
              <a href={speakerProposalUrl} target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto px-10 py-5 bg-transparent text-white border border-white/30 font-bold rounded-xl hover:bg-white/10 transition-colors text-lg hover:-translate-y-0.5 transform duration-200 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-slate-900">
                Gửi bài Trình bày
              </a>
            )}
          </div>
        </div>
      </section>

      {/* 2. About the Event */}
      {Content && (
        <section class="bg-slate-50 dark:bg-slate-900 py-24 border-b border-slate-200 dark:border-slate-800 transition-colors duration-300">
          <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12">
              <h2 class="text-sm font-bold tracking-widest uppercase text-primary dark:text-indigo-400 mb-2">Về Sự Kiện</h2>
              <div class="w-24 h-1 bg-primary/20 dark:bg-primary/40 mx-auto rounded"></div>
            </div>
            <div class="prose prose-lg prose-slate dark:prose-invert md:prose-xl mx-auto text-slate-700 dark:text-slate-300 leading-relaxed font-sans font-light">
              <Content /> 
            </div>
          </div>
        </section>
      )}

      {/* 3. Highlights Section */}
      {highlights && highlights.length > 0 && (
        <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
            {highlights.map(h => (
              <div class="bg-white dark:bg-slate-800 p-8 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
                <div class="w-12 h-12 bg-indigo-50 dark:bg-indigo-900/40 text-primary dark:text-indigo-400 rounded-xl flex items-center justify-center mb-6">
                  {h.icon ? (
                    <span class="text-2xl">{h.icon}</span>
                  ) : (
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                  )}
                </div>
                <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-3">{h.title}</h3>
                <p class="text-slate-600 dark:text-slate-400 leading-relaxed font-light">{h.description}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      {/* 4. Quick Links CTA */}
      <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
        <h2 class="text-3xl font-extrabold text-slate-900 dark:text-white mb-8 tracking-tight">Khám Phá Sự Kiện</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <a href={getPath('/agenda')} class="cursor-pointer bg-indigo-50 dark:bg-slate-800 p-8 rounded-2xl border border-indigo-100 dark:border-slate-700 hover:shadow-xl hover:-translate-y-1 hover:border-primary/30 transition-all duration-300 ease-out flex flex-col items-center group">
            <svg class="w-10 h-10 text-primary dark:text-indigo-400 mb-4 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <h3 class="text-xl font-bold text-slate-900 dark:text-white">Lịch trình</h3>
            <p class="text-slate-600 dark:text-slate-400 mt-2 font-light">Xem toàn bộ lịch trình</p>
          </a>
          <a href={getPath('/speakers')} class="cursor-pointer bg-indigo-50 dark:bg-slate-800 p-8 rounded-2xl border border-indigo-100 dark:border-slate-700 hover:shadow-xl hover:-translate-y-1 hover:border-primary/30 transition-all duration-300 ease-out flex flex-col items-center group">
            <svg class="w-10 h-10 text-primary dark:text-indigo-400 mb-4 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
            <h3 class="text-xl font-bold text-slate-900 dark:text-white">Diễn giả</h3>
            <p class="text-slate-600 dark:text-slate-400 mt-2 font-light">Gặp gỡ các chuyên gia</p>
          </a>
          <a href={getPath('/location')} class="cursor-pointer bg-indigo-50 dark:bg-slate-800 p-8 rounded-2xl border border-indigo-100 dark:border-slate-700 hover:shadow-xl hover:-translate-y-1 hover:border-primary/30 transition-all duration-300 ease-out flex flex-col items-center group">
            <svg class="w-10 h-10 text-primary dark:text-indigo-400 mb-4 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <h3 class="text-xl font-bold text-slate-900 dark:text-white">Địa điểm & Câu Hỏi Thường Gặp</h3>
            <p class="text-slate-600 dark:text-slate-400 mt-2 font-light">Thông tin địa điểm và giải đáp</p>
          </a>
        </div>
      </section>
    
      <div class="py-16 bg-white dark:bg-slate-950 border-t border-slate-100 dark:border-slate-800 text-center transition-colors duration-300">
        <a href={getPath("/editions")} class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold rounded-xl text-primary dark:text-indigo-400 hover:text-blue-700 dark:hover:text-indigo-300 bg-indigo-50 dark:bg-indigo-900/40 hover:bg-indigo-100 dark:hover:bg-indigo-900/60 transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 dark:focus:ring-offset-slate-900">
           Xem Các Sự Kiện Trước Đây
          <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </>
  )}
</BaseLayout>
