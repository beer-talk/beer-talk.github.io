---
import type { CollectionEntry } from 'astro:content';
import { getPath } from '../utils/paths';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, date, summary, tags } = post.data;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});
---
<a href={getPath(`/posts/${post.id}`)} class="block group h-full focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded-2xl">
  <article class="bg-white dark:bg-slate-900 p-6 sm:p-8 rounded-2xl border border-slate-200 dark:border-slate-800 hover:border-primary/30 dark:hover:border-primary/50 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 h-full flex flex-col relative overflow-hidden">
    <div class="absolute inset-x-0 top-0 h-1 bg-slate-100 dark:bg-slate-800 group-hover:bg-primary transition-colors"></div>
    
    <div class="flex items-center text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-4 gap-3">
      <time datetime={date.toISOString()}>{formattedDate}</time>
    </div>
    
    <h3 class="text-xl sm:text-2xl font-extrabold text-slate-900 dark:text-white group-hover:text-primary transition-colors mb-3 leading-tight line-clamp-2">
      {title}
    </h3>
    
    <p class="text-slate-600 dark:text-slate-400 leading-relaxed line-clamp-3 mb-6 flex-grow font-light">
      {summary}
    </p>
    
    <div class="mt-auto border-t border-slate-100 dark:border-slate-800 pt-5 flex items-center justify-between">
      <div class="flex items-center gap-2 overflow-hidden">
        {tags && tags.slice(0, 2).map((tag: unknown) => (
          <span class="px-2 py-0.5 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 text-xs font-medium rounded-md truncate">#{tag}</span>
        ))}
        {tags && tags.length > 2 && <span class="text-xs text-slate-400 dark:text-slate-500">+{tags.length - 2}</span>}
      </div>
      <div class="text-primary dark:text-indigo-400 font-bold text-sm bg-indigo-50/50 dark:bg-indigo-900/30 p-2 rounded-lg group-hover:bg-indigo-50 dark:group-hover:bg-indigo-900/50 transition-colors shrink-0">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </div>
    </div>
  </article>
</a>
