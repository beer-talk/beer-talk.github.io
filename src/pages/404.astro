---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPath } from '../utils/paths';
---

<BaseLayout title={`Page Not Found - {{SITE_NAME}}`} description="The page you are looking for does not exist.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 text-center flex flex-col items-center justify-center h-[60vh]">
    <h1 class="text-7xl font-extrabold text-blue-600 tracking-tight mb-4">404</h1>
    <h2 class="text-3xl font-bold text-gray-900 mb-6">Page Not Found</h2>
    <p class="text-xl text-gray-600 font-light mb-10 max-w-2xl mx-auto">
      We couldn't find the page you're looking for. It might have been moved or doesn't exist.
    </p>
    <a href={getPath('/')} class="px-8 py-4 bg-primary text-white font-semibold rounded-xl hover:bg-blue-700 transition-all shadow-md hover:shadow-lg text-lg">
      Return Home
    </a>
  </div>
</BaseLayout>
