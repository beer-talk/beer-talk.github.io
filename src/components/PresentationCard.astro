---
import type { CollectionEntry } from 'astro:content';
import { getPath } from '../utils/paths';

interface Props {
  presentation: CollectionEntry<'presentations'>;
}

const { presentation } = Astro.props;
const { title, date, summary, tags } = presentation.data;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});
---
<a href={getPath(`/presentations/${presentation.id}`)} class="block group h-full focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2">
  <article class="bg-white/50 dark:bg-[#0b0f19] p-6 sm:p-8 rounded-[2rem] border border-slate-200 dark:border-white/10 hover:border-primary/50 dark:hover:border-primary/50 hover:shadow-xl dark:hover:shadow-neon-primary transition-all duration-500 ease-out h-full flex flex-col relative overflow-hidden">
    <div class="absolute inset-x-0 top-0 h-1 bg-slate-200 dark:bg-white/10 group-hover:bg-primary dark:group-hover:bg-primary transition-colors duration-500"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-0"></div>
    
    <div class="relative z-10 flex flex-col h-full">
      <div class="flex items-center text-[10px] font-bold text-slate-400 dark:text-accent uppercase tracking-widest mb-4 gap-3">
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </div>
      
      <h3 class="text-2xl sm:text-3xl font-black text-slate-900 dark:text-white group-hover:text-primary dark:group-hover:text-accent transition-colors tracking-tight mb-4 leading-tight line-clamp-2 uppercase">
        {title}
      </h3>
      
      <p class="text-slate-600 dark:text-slate-400 leading-relaxed line-clamp-3 mb-8 flex-grow font-light">
        {summary}
      </p>
      
      <div class="mt-auto border-t border-slate-200 dark:border-white/10 pt-5 flex items-center justify-between">
        <div class="flex items-center gap-2 overflow-hidden">
          {tags && tags.slice(0, 2).map((tag: unknown) => (
            <span class="px-2 py-1 bg-slate-100 dark:bg-white/5 text-slate-600 dark:text-slate-300 text-[10px] uppercase tracking-wider font-bold border border-slate-200 dark:border-white/10 truncate">#{tag}</span>
          ))}
          {tags && tags.length > 2 && <span class="text-[10px] font-bold text-slate-400 dark:text-slate-500">+{tags.length - 2}</span>}
        </div>
        <div class="text-primary dark:text-accent font-bold pt-1 transition-transform transform group-hover:translate-x-1 shrink-0">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </div>
      </div>
    </div>
  </article>
</a>
