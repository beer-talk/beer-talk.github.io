---
import { SITE_CONFIG } from '../content/site-config';
import { getPath } from '../utils/paths';
import ThemeToggle from './ThemeToggle.astro';
---
<header class="bg-white/70 dark:bg-[#0b0f19]/80 backdrop-blur-xl border border-white/20 dark:border-white/10 sticky top-0 sm:top-6 z-50 transition-all duration-300 w-full sm:w-[calc(100%-2rem)] max-w-6xl mx-auto rounded-none sm:rounded-full shadow-sm dark:shadow-[0_8px_30px_rgb(0,0,0,0.6)]">
  <div class="px-4 sm:px-8">
    <div class="flex justify-between h-16 sm:h-20 items-center">
      <div class="flex shrink-0">
        <a href={getPath('/')} class="flex items-center group transition-transform hover:scale-105">
          <img src={getPath('/logo.png')} alt={SITE_CONFIG.name} class="h-8 sm:h-10 w-auto object-contain drop-shadow-sm dark:drop-shadow-[0_0_15px_rgba(255,255,255,0.2)] transition-all" />
        </a>
      </div>
      <nav class="hidden sm:flex sm:space-x-1 sm:items-center overflow-x-auto">
        <a href={getPath('/')} class="text-slate-700 dark:text-slate-300 hover:text-primary dark:hover:text-primary px-3 sm:px-4 py-2 text-[10px] sm:text-xs font-bold tracking-widest uppercase transition-colors hover:bg-primary/5 dark:hover:bg-primary/10 rounded-full whitespace-nowrap">Sự kiện</a>
        <a href={getPath('/agenda')} class="text-slate-700 dark:text-slate-300 hover:text-primary dark:hover:text-primary px-3 sm:px-4 py-2 text-[10px] sm:text-xs font-bold tracking-widest uppercase transition-colors hover:bg-primary/5 dark:hover:bg-primary/10 rounded-full whitespace-nowrap">Lịch trình</a>
        <a href={getPath('/speakers')} class="text-slate-700 dark:text-slate-300 hover:text-primary dark:hover:text-primary px-3 sm:px-4 py-2 text-[10px] sm:text-xs font-bold tracking-widest uppercase transition-colors hover:bg-primary/5 dark:hover:bg-primary/10 rounded-full whitespace-nowrap">Diễn giả</a>
        <a href={getPath('/call-to-talk')} class="text-white bg-primary hover:bg-orange-500 px-4 sm:px-5 py-2 text-[10px] sm:text-xs font-bold tracking-widest uppercase transition-all duration-300 rounded-full whitespace-nowrap shadow-sm shadow-primary/30 dark:shadow-neon-primary/30 hover:shadow-neon-primary mx-1">Call to Talk</a>
        <a href={getPath('/location')} class="text-slate-700 dark:text-slate-300 hover:text-primary dark:hover:text-primary px-3 sm:px-4 py-2 text-[10px] sm:text-xs font-bold tracking-widest uppercase transition-colors hover:bg-primary/5 dark:hover:bg-primary/10 rounded-full whitespace-nowrap">Địa điểm</a>
        <a href={getPath('/editions')} class="text-slate-700 dark:text-slate-300 hover:text-primary dark:hover:text-primary px-3 sm:px-4 py-2 text-[10px] sm:text-xs font-bold tracking-widest uppercase transition-colors hover:bg-primary/5 dark:hover:bg-primary/10 rounded-full whitespace-nowrap">Lưu trữ</a>
        <a href={getPath('/presentations')} class="text-slate-700 dark:text-slate-300 hover:text-primary dark:hover:text-primary px-3 sm:px-4 py-2 text-[10px] sm:text-xs font-bold tracking-widest uppercase transition-colors hover:bg-primary/5 dark:hover:bg-primary/10 rounded-full whitespace-nowrap">Thuyết trình</a>
        <a href={getPath('/donation')} class="text-slate-700 dark:text-slate-300 hover:text-primary dark:hover:text-primary px-3 sm:px-4 py-2 text-[10px] sm:text-xs font-bold tracking-widest uppercase transition-colors hover:bg-primary/5 dark:hover:bg-primary/10 rounded-full whitespace-nowrap">Tài trợ</a>
        <div class="pl-2 border-l border-slate-200 dark:border-white/10 ml-2">
          <ThemeToggle />
        </div>
      </nav>
    </div>
  </div>
</header>
